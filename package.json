{
  "name": "reder-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @rederjs/core && npm run build --workspaces --if-present",
    "watch": "tsc -b packages/core packages/cli packages/daemon packages/shim packages/adapter-telegram packages/adapter-web --watch",
    "dev": "npm run watch",
    "dev:web": "npm run dev:web -w @rederjs/adapter-web",
    "dev:web:lan": "npm run dev:web:lan -w @rederjs/adapter-web",
    "link": "npm link -w rederjs && npm link -w @rederjs/daemon && npm link -w @rederjs/shim",
    "unlink": "npm unlink -g rederjs @rederjs/daemon @rederjs/shim",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-plugin-security": "^3.0.0",
    "prettier": "^3.0.0"
  }
}
