{
  "name": "rederjs",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "reder": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./commands/sessions-repair": {
      "types": "./dist/commands/sessions-repair.d.ts",
      "default": "./dist/commands/sessions-repair.js"
    },
    "./commands/claude-hooks": {
      "types": "./dist/commands/claude-hooks.d.ts",
      "default": "./dist/commands/claude-hooks.js"
    }
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rederjs/core": "*",
    "commander": "^12.0.0",
    "prompts": "^2.4.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.0"
  }
}
